# Backend HTTP bind address
BACKEND_SERVER_ADDR=127.0.0.1:8080

# Agent base URL
AGENT_URL=http://127.0.0.1:3001

# Linux bridge name used by virt networking
BRIDGE_NAME=cloudebr0

# Network range (CIDR base address) for guest networking
IP_RANGE=10.39.1.0

# Network mask bits
IP_MASK=24

# Path to supported language images config
LANGUAGES_CONFIG_PATH=./config/languages.json

AGENT_BINARY_PATH=./cloude-agentd
INIT_SCRIPT_PATH=./init.sh
